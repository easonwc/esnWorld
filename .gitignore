# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local
!.env.example

# sqlite database
/data/
*.db
*.db-shm
*.db-wal

# downloaded country flag images (run npm run download-flags)
/public/flags/*
!/public/flags/.gitkeep

# downloaded NFL team logos (run npm run download-nfl-logos)
/public/logos/nfl/*
!/public/logos/nfl/.gitkeep

# downloaded MLB team logos (run npm run download-mlb-logos)
/public/logos/mlb/*
!/public/logos/mlb/.gitkeep

# downloaded NBA team logos (run npm run download-nba-logos)
/public/logos/nba/*
!/public/logos/nba/.gitkeep

# downloaded NHL team logos (run npm run download-nhl-logos)
/public/logos/nhl/*
!/public/logos/nhl/.gitkeep

# downloaded MLS team logos (run npm run download-mls-logos)
/public/logos/mls/*
!/public/logos/mls/.gitkeep

# downloaded WNBA team logos (run npm run download-wnba-logos)
/public/logos/wnba/*
!/public/logos/wnba/.gitkeep

# downloaded NCAA college logos (run npm run download-college-logos)
/public/logos/ncaa/*
!/public/logos/ncaa/.gitkeep

# downloaded league logos (synced on startup with league seeds)
/public/logos/leagues/*
!/public/logos/leagues/.gitkeep

# typescript
*.tsbuildinfo
next-env.d.ts
