# World Clock defaults
WORLD_CLOCK_INITIAL_ISO_UTC=2020-01-01T00:00:00.000Z
# 1 simulated minute (60,000 ms) advances per 1 real second (1,000 ms) → ratio of 60
WORLD_CLOCK_SIMULATED_MS_PER_REAL_MS=60

# Weather defaults
WEATHER_SEED=42
WEATHER_UNITS=fahrenheit
WEATHER_WIND_UNITS=mph

# Persistence (Phase 1: locations and venues)
DATABASE_PATH=./data/world.db

# Location seed (optional — merges catalog cities on server startup)
# When false, the database starts empty unless you create cities via the API.
LOCATIONS_SEED_ON_STARTUP=false

# NFL seed (optional — merges NFL league, conferences, divisions, teams, and stadium venues)
# Also ensures countries and locations exist. Downloads team logos to public/logos/nfl/.
NFL_SEED_ON_STARTUP=false

# MLB seed (optional — merges MLB league, conferences, divisions, teams, and ballpark venues)
# Also ensures countries and locations exist. Downloads team logos to public/logos/mlb/.
MLB_SEED_ON_STARTUP=false

# NBA seed (optional — merges NBA league, conferences, divisions, teams, and arena venues)
# Also ensures countries and locations exist. Downloads team logos to public/logos/nba/.
NBA_SEED_ON_STARTUP=false

# NHL seed (optional — merges NHL league, conferences, divisions, teams, and arena venues)
# Also ensures countries and locations exist. Downloads team logos to public/logos/nhl/.
NHL_SEED_ON_STARTUP=false

# MLS seed (optional — merges MLS league, conferences, divisions, teams, and stadium venues)
# Also ensures countries and locations exist. Downloads team logos to public/logos/mls/.
MLS_SEED_ON_STARTUP=false

# WNBA seed (optional — merges WNBA league, conferences, divisions, teams, and arena venues)
# Also ensures countries and locations exist. Downloads team logos to public/logos/wnba/.
WNBA_SEED_ON_STARTUP=false

# Country flags (optional — set true to skip downloading flag SVGs from the web)
# SKIP_FLAG_DOWNLOAD=true

# NFL team logos (optional — set true to skip downloading logo PNGs from the web)
# SKIP_NFL_LOGO_DOWNLOAD=true

# MLB team logos (optional — set true to skip downloading logo PNGs from the web)
# SKIP_MLB_LOGO_DOWNLOAD=true

# NBA team logos (optional — set true to skip downloading logo PNGs from the web)
# SKIP_NBA_LOGO_DOWNLOAD=true

# NHL team logos (optional — set true to skip downloading logo PNGs from the web)
# SKIP_NHL_LOGO_DOWNLOAD=true

# MLS team logos (optional — set true to skip downloading logo PNGs from the web)
# SKIP_MLS_LOGO_DOWNLOAD=true

# WNBA team logos (optional — set true to skip downloading logo PNGs from the web)
# SKIP_WNBA_LOGO_DOWNLOAD=true
