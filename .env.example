# World Clock defaults
WORLD_CLOCK_INITIAL_ISO_UTC=2020-01-01T00:00:00.000Z
# 1 simulated minute (60,000 ms) advances per 1 real second (1,000 ms) → ratio of 60
WORLD_CLOCK_SIMULATED_MS_PER_REAL_MS=60

# Weather defaults
WEATHER_SEED=42
WEATHER_UNITS=fahrenheit
WEATHER_WIND_UNITS=mph

# Persistence (Phase 1: locations and venues)
DATABASE_PATH=./data/world.db

# Delete the SQLite database on server startup and recreate empty tables.
# Use for a one-time fresh start; set back to false afterward.
DATABASE_RESET_ON_STARTUP=false

# Location seed (optional — merges catalog cities on server startup)
# When false, no seed data is merged (the database still persists across restarts).
LOCATIONS_SEED_ON_STARTUP=false

# NFL seed (optional — merges NFL league, conferences, divisions, teams, and stadium venues)
# Also ensures countries and locations exist.
NFL_SEED_ON_STARTUP=false

# MLB seed (optional — merges MLB league, conferences, divisions, teams, and ballpark venues)
# Also ensures countries and locations exist.
MLB_SEED_ON_STARTUP=false

# NBA seed (optional — merges NBA league, conferences, divisions, teams, and arena venues)
# Also ensures countries and locations exist.
NBA_SEED_ON_STARTUP=false

# NHL seed (optional — merges NHL league, conferences, divisions, teams, and arena venues)
# Also ensures countries and locations exist.
NHL_SEED_ON_STARTUP=false

# MLS seed (optional — merges MLS league, conferences, divisions, teams, and stadium venues)
# Also ensures countries and locations exist.
MLS_SEED_ON_STARTUP=false

# WNBA seed (optional — merges WNBA league, conferences, divisions, teams, and arena venues)
# Also ensures countries and locations exist.
WNBA_SEED_ON_STARTUP=false

# Asset downloads on server startup (default false — use npm run download-* scripts instead)
FLAG_DOWNLOAD_ON_STARTUP=false
NFL_LOGO_DOWNLOAD_ON_STARTUP=false
MLB_LOGO_DOWNLOAD_ON_STARTUP=false
NBA_LOGO_DOWNLOAD_ON_STARTUP=false
NHL_LOGO_DOWNLOAD_ON_STARTUP=false
MLS_LOGO_DOWNLOAD_ON_STARTUP=false
WNBA_LOGO_DOWNLOAD_ON_STARTUP=false
